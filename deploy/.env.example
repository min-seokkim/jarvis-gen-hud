# cp .env.example .env 후 값 채우기. .env 는 절대 커밋하지 말 것.

# --- Hermes API (React가 /v1/* 로 붙음) ---
# 강한 랜덤 키. 예: openssl rand -hex 32
# 프론트엔 안 들어가고, Caddy가 /v1 프록시에 Bearer로 주입한다.
API_SERVER_KEY=

# --- 공개 종단 (Caddy) ---
# RDP에 쓰는 DDNS 도메인 (이 호스트로 자동 HTTPS 발급). 예: myhome.duckdns.org
DDNS_DOMAIN=
# 데모장에서 사이트 들어갈 때 쓰는 basic-auth 계정.
BASIC_AUTH_USER=demo
# bcrypt 해시 생성:  docker run --rm caddy:2 caddy hash-password --plaintext '여기에_비번'
# 출력된 $2a$... 해시를 그대로 넣기 (compose에서 $는 $$ 로 이스케이프 필요할 수 있음).
BASIC_AUTH_HASH=

# --- 컨테이너 파일 권한 (호스트 uid/gid 매핑) ---
# 인라인으로 줘도 됨: HERMES_UID=$(id -u) HERMES_GID=$(id -g) docker compose up -d
HERMES_UID=
HERMES_GID=

# LLM 프로바이더 키는 `docker compose run --rm gateway hermes setup` 마법사에서
# 넣는 게 기본(=> ~/.hermes 에 저장). env로 직접 줄 수도 있음:
# OPENROUTER_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
